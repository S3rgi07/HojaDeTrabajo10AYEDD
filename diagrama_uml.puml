@startuml HT10_Floyd_UML

skinparam classAttributeIconSize 0
skinparam backgroundColor #FEFEFE
skinparam class {
    BackgroundColor #EEF5FF
    BorderColor #336699
    HeaderBackgroundColor #336699
    HeaderFontColor white
    ArrowColor #336699
}

title CC2003 – HT10: Algoritmo de Floyd\nUniversidad del Valle de Guatemala – 2020

class Grafo {
    - {static} INFINITO : double
    - vertices : List<String>
    - matrizAdyacencia : double[][]
    - capacidad : int
    --
    + Grafo()
    + agregarVertice(nombre: String) : void
    + contieneVertice(nombre: String) : boolean
    + indiceVertice(nombre: String) : int
    + getVertices() : List<String>
    + cantidadVertices() : int
    + agregarArco(origen: String, destino: String, peso: double) : void
    + eliminarArco(origen: String, destino: String) : void
    + existeArco(origen: String, destino: String) : boolean
    + getPeso(origen: String, destino: String) : double
    + getMatrizAdyacencia() : double[][]
    + mostrarMatriz() : void
}

class Floyd {
    - grafo : Grafo
    - distancias : double[][]
    - siguiente : int[][]
    - vertices : List<String>
    - n : int
    --
    + Floyd(grafo: Grafo)
    + ejecutar() : void
    + getDistancia(origen: String, destino: String) : double
    + getRuta(origen: String, destino: String) : List<String>
    + getCentroGrafo() : String
    + calcularExcentricidades() : double[]
    + mostrarMatrizDistancias() : void
    + mostrarExcentricidades() : void
}

class LectorGrafo {
    + {static} leerArchivo(ruta: String) : Grafo
}

class Main {
    - {static} grafo : Grafo
    - {static} floyd : Floyd
    - {static} sc : Scanner
    --
    + {static} main(args: String[]) : void
    - {static} mostrarMenu() : void
    - {static} consultarRuta() : void
    - {static} mostrarCentro() : void
    - {static} modificarGrafo() : void
    - {static} obtenerCentro() : String
    - {static} mostrarCiudades() : void
    - {static} imprimirBanner() : void
}

Floyd --> Grafo : usa >
LectorGrafo ..> Grafo : crea >
Main --> Grafo : gestiona >
Main --> Floyd : ejecuta >
Main ..> LectorGrafo : usa >

note right of Floyd
  Algoritmo de Floyd-Warshall O(n³)
  
  Centro del Grafo (CentroDeGrafo.pdf):
  1. Calcular APSP → distancias[][]
  2. Para cada columna i:
     excentricidad(i) = max{dist[w][i]}
  3. Centro = min{excentricidad}
end note

note right of Grafo
  Representación por Matriz de Adyacencia.
  Grafo dirigido y ponderado.
  Nodos: ciudades de Guatemala.
  Arcos: distancia en KM.
end note

@enduml
